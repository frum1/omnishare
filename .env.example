# HEY YOU! PLEASE READ THIS BEFORE COPYING THIS FILE TO .env
# This file is an example configuration for OmniShare. It contains all the
# available settings, with their default values. Copy it to .env and edit the
# values to your liking.

# Public URL the service is exposed on. Used both for the public share links
# and — with the "proxy" profile below — as Caddy's site address (its https://
# host is what triggers automatic certificate provisioning).
PUBLIC_BASE_URL=https://example.com

# Local address of the server on the home network.
# Leave empty to auto-detect (outbound interface IP + LOCAL_PORT).
LOCAL_BASE_URL=

# Port uvicorn listens on - also used when auto-detecting LOCAL_BASE_URL
LOCAL_PORT=8010

# Enable local-network share links (exposed to users via /api/local-mode-available)
LOCAL_MODE=true

# JWT signing key. Leave unset to auto-generate a random key on first boot,
# persisted to data/secret_key. Set explicitly only to share a key across
# separate instances.
# SECRET_KEY=

# If you dont know what this is, leave it at the default.
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=sqlite+aiosqlite:///./data/omnishare.db

# Dont edit this. Real storage location is configured in docker-compose.yml.
STORAGE_DIR=./storage

# Maximum file size in megabytes
MAX_FILE_SIZE_MB=1024

# Chunk size used for streaming uploads, in kilobytes
UPLOAD_CHUNK_SIZE_KB=1024

# How often (in minutes) the background job purges expired files
CLEANUP_INTERVAL_MINUTES=30

# --- Public HTTPS via Caddy ---
# Uncomment to run the bundled Caddy reverse proxy, which obtains and renews a
# Let's Encrypt certificate for PUBLIC_BASE_URL automatically. Requires DNS for
# that host pointed at this server and ports 80/443 forwarded to it. Leave
# commented for a plain-HTTP / LAN-only setup.
# COMPOSE_PROFILES=proxy
