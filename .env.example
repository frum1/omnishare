# Публичный домен, на который проброшен сервис (используется во второй ссылке)
PUBLIC_BASE_URL=https://example.com

# Локальный адрес сервера в домашней сети.
# Если оставить пустым - будет определён автоматически (IP исходящего интерфейса + LOCAL_PORT).
LOCAL_BASE_URL=

# Порт, который слушает uvicorn - используется при автоопределении LOCAL_BASE_URL
LOCAL_PORT=8000

# Ключ для подписи JWT. Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATABASE_URL=sqlite+aiosqlite:///./data/hshare.db
STORAGE_DIR=./storage

# Максимальный размер файла в мегабайтах
MAX_FILE_SIZE_MB=1024

# Размер чанка при потоковой загрузке, в килобайтах
UPLOAD_CHUNK_SIZE_KB=1024

# Как часто (в минутах) фоновая задача удаляет просроченные файлы
CLEANUP_INTERVAL_MINUTES=30
