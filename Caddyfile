# Reverse proxy + automatic HTTPS for OmniShare. Caddy requests and renews
# a Let's Encrypt certificate for {$DOMAIN} on its own — no certbot, no cron.
#
# Prerequisites (outside Caddy's control):
#   - DNS: {$DOMAIN} must resolve to this server's public IP.
#   - Router/firewall: ports 80 and 443 forwarded to this machine (80 is
#     needed for the ACME HTTP-01 challenge, not just redirects).
{$DOMAIN} {
	reverse_proxy localhost:{$LOCAL_PORT}
}
