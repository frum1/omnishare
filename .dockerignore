# Virtualenv and Python caches
.venv/
__pycache__/
*.pyc

# Local runtime data — must never leak into the image (mounted as volumes)
data/
storage/
web/dist/

# Frontend is fetched fresh from a release during the build, never copied
# from the local tree.
dist/

# Local config and secrets
.env

# VCS and editor
.git/
.gitignore
.idea/
.vscode/

# Docs / meta
README.md
